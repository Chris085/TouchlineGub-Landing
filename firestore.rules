rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Rules for each collection
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
    }

    match /matches/{matchId} {
      allow read, write: if isSignedIn();
    }

    match /availabilities/{availabilityId} {
      allow read, write: if isSignedIn();
    }

    match /motmVotes/{voteId} {
      allow read, write: if isSignedIn();
    }

    match /attendances/{attendanceId} {
      allow read, write: if isSignedIn();
    }

    match /playerNotes/{noteId} {
      allow read, write: if isSignedIn();
    }

    match /notes/{noteId} {
      allow read, write: if isSignedIn();
    }

    match /subscriptions/{subscriptionId} {
      allow read, write: if isSignedIn();
    }

    match /coachCodes/{codeId} {
      allow read, write: if isSignedIn();
    }

    match /playerPayments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    match /paymentTransactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    match /monthlySubs/{subId} {
      allow read, write: if isSignedIn();
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

